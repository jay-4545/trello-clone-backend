{
  "name": "trello-api",
  "version": "1.0.0",
  "description": "Production-ready Trello-like API with real-time, RBAC, and load-balancing",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:cluster": "node dist/cluster.js",
    "typecheck": "tsc --noEmit",
    "seed": "ts-node-dev --transpile-only src/seed.ts",
    "seed:prod": "node dist/seed.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.0",
    "cloudinary": "^2.4.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "rate-limit-redis": "^4.2.0",
    "sequelize": "^6.37.8",
    "socket.io": "^4.7.4",
    "uuid": "^14.0.0",
    "winston": "^3.12.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^9.0.8",
    "sequelize-cli": "^6.6.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}